# Local automatic agent runtime logs
.agent-logs/*
!.agent-logs/README.md

# Run-local artifacts and heavy evidence
artifacts/**/runs/
artifacts/**/evidence/

# Playwright outputs
test-results/
playwright-report/
blob-report/

# Heavy media / traces
*.webm
*.mp4
*.trace.zip

# Keep durable artifact templates and scope-level handoff files
!artifacts/_templates/
!artifacts/_templates/**
!artifacts/service-exploration/
!artifacts/service-exploration/*.md
!artifacts/spec-catalog/
!artifacts/spec-catalog/**

# Saved browser authentication state
artifacts/**/auth/
*.auth.json
storage-state*.json

# Runtime / language caches
node_modules/
__pycache__/
*.pyc

.playwright-cli/

# Playwright
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/
experiments

# TypeScript build info
*.tsbuildinfo
demo-apps/**/*.tsbuildinfo

# Demo app build output
demo-apps/**/dist/
demo-apps/**/node_modules/
demo-apps/**/coverage/
demo-apps/**/playwright-report/
demo-apps/**/test-results/

dist/*
