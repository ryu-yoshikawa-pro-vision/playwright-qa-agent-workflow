{
  "globs": ["**/*.md"],
  "ignores": [
    "node_modules",
    ".agents",
    ".opencode",
    ".playwright-cli",
    "playwright-report",
    "test-results",
    "coverage",
    ".agent-logs",
    "artifacts/**/runs",
    "artifacts/**/evidence",
  ],
  "config": {
    "default": true,
    "MD013": false,
    "MD024": false,
    "MD033": false,
    "MD041": false,
  },
}
